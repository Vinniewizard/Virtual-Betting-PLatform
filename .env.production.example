# Production runtime settings
NODE_ENV=production
PORT=3001

# Set a long random secret before deployment.
# Example generation:
#   openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Use an absolute path in production
DB_FILE=/var/lib/betting_server/betting.db

# Request size limit for admin JSON endpoints
MAX_BODY_SIZE_BYTES=102400

# Keep admin seeding disabled in production by default.
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_BALANCE=10000
